{
  "name": "frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "test:unit": "vitest run --reporter=verbose test/unit-tests",
    "test:unit:watch": "vitest test/unit-tests",
    "test:component": "vitest run --reporter=verbose test/component-tests",
    "test": "npm run test:unit && npm run test:component",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@aws-sdk/client-cognito-identity-provider": "^3.797.0",
    "@tanstack/react-query": "^5.95.0",
    "api-spec": "*",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.577.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-icons": "^5.6.0",
    "react-router-dom": "^7.6.2",
    "zod": "^4.1.5",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.0",
    "@tailwindcss/vite": "^4.1.11",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^6.0.0",
    "eslint": "^10.0.0",
    "globals": "^16.2.0",
    "jsdom": "^29.0.1",
    "tailwindcss": "^4.1.11",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.33.1",
    "vite": "^8.0.5",
    "vitest": "^4.1.0"
  }
}

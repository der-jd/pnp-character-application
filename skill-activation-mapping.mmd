flowchart LR
    %% ── XML source states ──────────────────────────────────
    subgraph XML["XML Source States"]
        direction TB
        S["Start Skill\n(no &lt;activated&gt; field)"]
        A["Activated Skill\n(&lt;activated&gt;1)"]
        D["Deactivated Skill\n(&lt;activated&gt;-xxx)"]
    end

    %% ── Points check ───────────────────────────────────────
    S --> S_NP{"No points"}
    S --> S_WP{"With points"}

    A --> A_NP{"No points"}
    A --> A_WP{"With points"}

    D --> D_NP{"No points"}
    D --> D_WP{"With points"}

    %% ── Start Skill paths ──────────────────────────────────
    S_NP -->|"Start skill\n(new)"| S_NP_SS["Ignore\n(nothing to do)"]
    S_NP -->|"No start skill\n(new)"| S_NP_NS["Ignore\n(nothing to do)"]
    S_WP -->|"Start skill\n(new)"| S_WP_SS["Transfer points"]
    S_WP -->|"No start skill\n(new)"| S_WP_NS["Activate +\ntransfer points"]

    %% ── Activated Skill paths ──────────────────────────────
    A_NP -->|"Start skill\n(new)"| A_NP_SS["Ignore\n(nothing to do)"]
    A_NP -->|"No start skill\n(new)"| A_NP_NS["Activate"]
    A_WP -->|"Start skill\n(new)"| A_WP_SS["Transfer points"]
    A_WP -->|"No start skill\n(new)"| A_WP_NS["Activate +\ntransfer points"]

    %% ── Deactivated Skill paths ────────────────────────────
    D_NP -->|"Start skill\n(new)"| D_NP_SS["Ignore\n(nothing to do)"]
    D_NP -->|"No start skill\n(new)"| D_NP_NS["Ignore\n(nothing to do)"]
    D_WP --> D_BUG["Bug in XML\n(assumed impossible)"]

    %% ── Styling ────────────────────────────────────────────
    classDef source fill:#4a6fa5,stroke:#2d4a7a,color:#fff
    classDef decision fill:#f5c542,stroke:#c49a20,color:#333
    classDef ignore fill:#6c757d,stroke:#495057,color:#fff
    classDef action fill:#28a745,stroke:#1e7e34,color:#fff
    classDef bug fill:#dc3545,stroke:#a71d2a,color:#fff

    class S,A,D source
    class S_NP,S_WP,A_NP,A_WP,D_NP,D_WP decision
    class S_NP_SS,S_NP_NS,A_NP_SS,D_NP_SS,D_NP_NS ignore
    class S_WP_SS,S_WP_NS,A_NP_NS,A_WP_SS,A_WP_NS action
    class D_BUG bug

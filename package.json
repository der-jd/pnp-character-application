{
  "name": "pnp-application",
  "version": "0.0.0",
  "description": "Version field not used.",
  "private": true,
  "workspaces": [
    "backend",
    "frontend",
    "scripts",
    "api-spec",
    "backend/src/core",
    "backend/src/lambdas/*"
  ],
  "scripts": {
    "prepare": "husky",
    "install-lint-terraform": "curl --silent https://raw.githubusercontent.com/terraform-linters/tflint/master/install_linux.sh | TFLINT_VERSION=\"v0.57.0\" bash && tflint --init",
    "format": "prettier . --write",
    "check-format": "prettier . --check",
    "lint:terraform": "tflint --chdir=terraform && echo \"SUCCESS: No lint errors found!\"",
    "lint": "npm run lint --workspaces --if-present",
    "build": "cd api-spec && npm run build && cd .. && npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present"
  },
  "overrides": {
    "flatted": "3.4.2"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "prettier": "^3.5.3",
    "prettier-plugin-terraform-formatter": "^1.2.1"
  }
}
